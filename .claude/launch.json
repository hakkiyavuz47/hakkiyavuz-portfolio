{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Site",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "static", "-p", "3000", "-n"],
      "port": 3000
    },
    {
      "name": "Vite Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Vite Preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "port": 4173
    },
    {
      "name": "Wrangler Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "deploy"],
      "port": 8787
    }
  ]
}
